@* Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMCS</title>

    <!-- Tailwind CSS via CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- GSAP Animation Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="~/favicon.png" />

    @RenderSection("HeadContent", required: false)
</head>
<body class="bg-gray-50 text-gray-900 flex flex-col min-h-screen">
    <!-- Navbar -->
    <header class="bg-gradient-to-r from-indigo-600 via-purple-600 to-pink-500 shadow-lg">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <!-- Logo -->
                <a asp-controller="Home" asp-action="Index" class="text-2xl font-bold text-white hover:scale-105 transition">
                    CMCS
                </a>

                <!-- Navigation Links -->
                <div class="hidden md:flex space-x-8">
                    <a asp-controller="Home" asp-action="Index" class="text-white hover:text-yellow-300 transition">Home</a>
                    <a asp-controller="Lecturer" asp-action="Submit" class="text-white hover:text-yellow-300 transition">Lecturer</a>
                    <a asp-controller="Coordinator" asp-action="Index" class="text-white hover:text-yellow-300 transition">Coordinator</a>
                    <a asp-controller="Manager" asp-action="Index" class="text-white hover:text-yellow-300 transition">Manager</a>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content Area -->
    <main role="main" class="flex-grow">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 py-6 text-center">
        <p>&copy; @DateTime.Now.Year CMCS - Contract Monthly Claim System. All Rights Reserved.</p>
    </footer>

    <!-- Custom Page-Specific Scripts -->
    @RenderSection("Scripts", required: false)

    <!-- GSAP Global Animations -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Animate navbar on page load
            gsap.from("header", {
                y: -100,
                opacity: 0,
                duration: 1,
                ease: "power2.out"
            });

            // Animate footer on load
            gsap.from("footer", {
                y: 100,
                opacity: 0,
                duration: 1,
                delay: 0.5,
                ease: "power2.out"
            });
        });
    </script>
</body>
</html>
